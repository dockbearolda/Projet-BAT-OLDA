{
	# Railway expose le port via $PORT, on lui obéit (sinon 80 en local).
	auto_https off
	admin off
}

:{$PORT:80} {
	root * /srv
	encode gzip zstd
	file_server

	# SPA fallback : toutes les routes non-asset retournent index.html
	try_files {path} /index.html

	# Cache long pour les mockups et fonts (immutables, hashés ou rares)
	@static {
		path /mockups/* /assets/* *.ttf *.woff2 *.webp
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# manifest.json mis à jour à chaque déploiement → cache court
	header /manifest.json Cache-Control "no-cache"

	# HTML jamais caché
	header /index.html Cache-Control "no-cache"
	header / Cache-Control "no-cache"
}
